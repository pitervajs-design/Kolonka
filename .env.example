# === OpenRouter API ===
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Модель для аудио-ввода/вывода (STT/TTS в pipeline-режиме)
AI_MODEL=openai/gpt-4o-audio-preview

# Голос ответа AI
AI_VOICE=nova
TTS_VOICE=ru-RU-DmitryNeural

# Системный промпт
SYSTEM_PROMPT=Ты - умный голосовой помощник по имени Джарвис, встроенный в колонку Divoom Timebox Evo. Отвечай кратко и по делу на русском языке. Ты дружелюбный и полезный.

# === Режим работы ===
AUDIO_MODE=timebox
AI_MODE=pipeline
LLM_MODEL=x-ai/grok-4.1-fast

# === Микрофон ===
MIC_DEVICE=

# === Divoom Timebox Evo ===
TIMEBOX_COM_PORT=COM5
TIMEBOX_BAUD_RATE=115200
DISPLAY_BRIGHTNESS=80
IDLE_DISPLAY=icon

# === VAD ===
VAD_THRESHOLD=500
VAD_SILENCE_MS=1500

# === Wake Word ===
WAKE_WORD=true

# === Аудио ===
RECORD_SAMPLE_RATE=16000
PLAYBACK_SAMPLE_RATE=24000
MAX_RECORD_SECONDS=30

# === Локальный STT (Vosk) ===
LOCAL_STT=true
# VOSK_MODEL_PATH=  # по умолчанию: models/vosk-model-small-ru-0.22

# === История ===
MAX_HISTORY=50
